{
  "name": "resq",
  "private": true,
  "version": "0.0.0",
  "description": "Local-first desktop app for converting messy text into structured Markdown.",
  "author": "KIKA",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "node node_modules/vite/bin/vite.js --port=3000 --host=0.0.0.0",
    "build": "node node_modules/vite/bin/vite.js build",
    "desktop:dev": "node node_modules/concurrently/dist/bin/concurrently.js -k \"npm:dev\" \"npm:desktop:start\"",
    "desktop:start": "node node_modules/wait-on/bin/wait-on tcp:3000 && node node_modules/electron/cli.js .",
    "desktop:build": "npm run build && node node_modules/electron-builder/cli.js --dir",
    "desktop:dist": "npm run build && node node_modules/electron-builder/cli.js",
    "preview": "node node_modules/vite/bin/vite.js preview",
    "clean": "rm -rf dist",
    "lint": "node node_modules/typescript/bin/tsc --noEmit",
    "test": "node --test src/lib/markdownParser.test.ts src/lib/markdownRescue.test.ts src/lib/ollama.test.ts"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "html2pdf.js": "^0.14.0",
    "lucide-react": "^0.546.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "concurrently": "^9.2.1",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.kika.resq",
    "productName": "RESQ",
    "icon": "public/icon.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "icon": "assets/branding/resq-icon.icns",
      "category": "public.app-category.productivity",
      "target": [
        "dir",
        "dmg"
      ]
    }
  }
}
